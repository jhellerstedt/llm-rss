# Copy to .env in the repo root and fill in values. .env is gitignored.
# Do not commit real keys to this public repository.

# Required for Kagi (FastGPT / Summarizer)
KAGI_API_KEY=

# Optional: OpenRouter (when [openrouter] is enabled in config.toml)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=~anthropic/claude-haiku-latest

# Optional: OpenAlex contact
# OPENALEX_MAILTO=you@example.com

# Optional: Zulip (alternative to config.d/zulip_realms.json)
# ZULIP_REALMS_CONFIG_FILE=config.d/zulip_realms.json
# ZULIP_REALM_MYREALM_EMAIL=bot@example.com
# ZULIP_REALM_MYREALM_API_KEY=
# ZULIP_REALM_MYREALM_SITE=https://chat.example.com
