# Kagi API: prefer KAGI_API_KEY in .env (see .env.example); api_key here also works in local config.toml
[kagi]
# api_key = "your-token"
fastgpt_url = "https://kagi.com/api/v0/fastgpt"
summarize_url = "https://kagi.com/api/v0/summarize"
web_search = true
summarize_engine = "cecil" # "muriel" is extremely expensive
fastgpt_timeout = 120
summarize_timeout = 180
use_cache = true
# Limit parallel FastGPT/Summarizer HTTP calls (strongly reduces 429 rate limits)
max_concurrent_api_requests = 2
# Minimum seconds between the start of successive Kagi HTTP requests (eases read timeouts under load)
min_seconds_between_requests = 2
# Retries per request (429 / transient 5xx / read timeout)
max_http_attempts = 12
# Local keyword shortlist before Kagi; articles are scored in batches (fewer FastGPT calls).
prefilter_max_candidates = 20
scoring_batch_size = 5

[openrouter]
# api_key = "your-openrouter-key"  # prefer OPENROUTER_API_KEY in .env (see .env.example)
# model = "~anthropic/claude-haiku-latest"  # always tracks latest Haiku; see https://openrouter.ai/models
# timeout = 60
# site_url = "https://yourserver.example.com"
# site_name = "llm-rss"

# Which call types to route to OpenRouter instead of Kagi:
# "scoring"    — article relevance/impact scoring (high volume; recommended)
# "summarize"  — Zulip context compression when > context_max_chars
# "curate"     — research_areas / excluded_areas curation from Zulip
# "domains"    — academic journal domain classification
route_to_openrouter = ["scoring", "summarize", "curate", "domains"]

# OpenAlex metadata for feed items (h-index, first/last author affiliations).
# Set mailto so OpenAlex can contact you if needed (also configurable via OPENALEX_MAILTO).
[openalex]
enabled = true
# When OpenAlex leaves name/affiliations as Unknown, ask Kagi FastGPT (extra API calls).
kagi_fallback = true
# mailto = "you@example.com"

# Channel <link> value used in RSS XML output (per-group override supported via groups[].feed_link).
feed_link = "jhell.imipolex.biz/feeds"

# Zulip realms: JSON map realm_name -> { email, api_key, site }
# Or set ZULIP_REALMS_CONFIG_FILE / ZULIP_REALM_<NAME>_EMAIL, etc. (see README)
[zulip]
# realms_config_file = "zulip_realms.json"
context_max_chars = 12000
# When groups use zulip_sources, post a weekly digest of config.toml edits to topic "journal suggestions".
# journal_weekly_summary = false
#
# When true, top "feedback ranking" picks are appended to a JSON queue next to this TOML instead of posting
# immediately. Drain the queue with hourly cron, for example:
#   0 * * * * cd /path/to/llm-rss && .venv/bin/python main.py --dispatch-feedback-queue --config-path config.d/config.toml
# Each run posts at most one queued paper per Zulip stream (topic "feedback ranking"),
# and only after the latest post in that topic has a :thumbs_up: or :thumbs_down: reaction.
# feedback_ranking_use_queue = true
# Optional queue file path (relative to this TOML's directory; default: <stem>.feedback_ranking_queue.json).
# feedback_ranking_queue_file = "data/feedback_ranking_queue.json"

# Post a deduplicated WARNING/ERROR summary to Zulip when a run hits issues (skipped when clean).
# [zulip.error_reporting]
# enabled = true
# topic = "llm-rss run"
# realm = "myrealm"
# stream = "llm errors"
# Or multiple realms (same summary posted to each):
# [[zulip.error_reporting.destinations]]
# realm = "realm_a"
# stream = "llm errors"
# [[zulip.error_reporting.destinations]]
# realm = "realm_b"
# stream = "llm errors"

# Adaptive feedback control (requires groups with zulip_sources). Adjusts each group's
# effective relevance/impact thresholds from recent :+1:/:-1: reactions (target 80% +1)
# and scales feedback enqueue rate to match Zulip post consumption. State file:
# <config-stem>.feedback_control.json (override with file= below).
# [feedback_control]
# enabled = true
# target_up_ratio = 0.80
# consumption_window_days = 7
# ratio_sample_size = 20
# ratio_min_samples = 5
# max_threshold_margin = 3
# max_enqueue_per_run = 2
# target_queue_depth = 2
# margin_step = 1
# ratio_deadband = 0.10
# file = "data/feedback_control.json"

# Author whitelist: papers by these authors are ALWAYS included, bypassing the
# relevance/impact thresholds. Manage it from Zulip by posting in `command_source`:
#   add https://orcid.org/0000-0002-1825-0097
#   add https://scholar.google.com/citations?user=XXXX
#   remove 0000-0002-1825-0097     (or an OpenAlex id, or a display name)
#   list
# Matching is by author name (aliases captured from ORCID/OpenAlex at add time), so
# it fires immediately—even on same-day articles OpenAlex hasn't indexed yet.
# The whitelist file is JSON, stored next to this config (gitignored as local state).
# [author_whitelist]
# enabled = true
# file = "author_whitelist.json"
# command_source = { realm = "myrealm", stream = "papers", topic = "author whitelist", lookback_hours = 168, max_messages = 200 }

# Topical group 1: condensed matter / general physics journals
[[groups]]
name = "cm_physics"
# Optional: single token appended to RSS channel <description> as "— category: …" for site grouping.
# Alias key: `category` (same meaning).
feed_category = "cm"
urls = [
    "https://www.nature.com/ncomms.rss",
    "https://www.nature.com/nphys.rss",
    "http://feeds.aps.org/rss/recent/prl.xml",
]
research_areas = [
    "condensed matter physics, experimental methods",
    "computational physics",
]
excluded_areas = [
    "fusion plasma physics",
]
period = 24
rss_path = "data/cm_physics.xml"
relevance_threshold = 5
impact_threshold = 3
# concurrent_requests = 2
# crawl_abstract = false

# Optional: pull discussion context from Zulip (requires zulip_realms.json or env realms).
# Each row's optional "topic" / lookback only affect discussion context, not feedback.
# When zulip_sources is set, the bot also posts feedback-ranking picks each group run
# (highest-ranked passing papers by relevance then impact; count adapts when
# [feedback_control] is enabled — see below). Skips links already present in each
# stream's "feedback ranking" topic. The same paper URL in multiple [[groups]]
# appears in only one group's RSS feed and at most one feedback-ranking post per run—the group
# where it scored highest on relevance (then impact).
# If you list multiple realm/stream rows,
# the budget is shared across them (earlier rows in config order are tried first). Those
# messages live on each row's realm+stream under topic "feedback ranking"; :thumbs_up: /
# :thumbs_down: reactions there inform later scoring runs.
# zulip_sources = [
#   { realm = "myrealm", stream = "papers", lookback_hours = 168, max_messages = 400 },
#   { realm = "myrealm", stream = "lab", topic = "reading", lookback_hours = 72, max_messages = 200 },
# ]

# Topical group 2: preprints example
[[groups]]
name = "plasma_preprints"
feed_category = "plasma"
urls = [
    "http://rss.arxiv.org/rss/physics.plasm-ph",
]
research_areas = [
    "laboratory plasma physics",
    "diagnostics",
]
excluded_areas = []
period = 24
rss_path = "data/plasma_preprints.xml"
relevance_threshold = 5
impact_threshold = 3
